# Hodlsmith — local environment template
# Copy this file to .env.local and fill in values.

# ------------ Telegram (only for the Telegram surface) ------------
# From @BotFather: /newbot
TELEGRAM_BOT_TOKEN=

# ------------ Flock.io (required: LLM provider) ------------
# https://docs.flock.io/flock-products/api-platform
# Auth quirk: Flock uses x-litellm-api-key header (non-standard)
FLOCK_API_KEY=
FLOCK_BASE_URL=https://api.flock.io/v1
FLOCK_MODEL=qwen3-30b-a3b-instruct-2507

# ------------ Nansen (required: on-chain data) ------------
# Nansen Pro plan with API access required.
# Endpoints used: profiler/address/current-balance, smart-money/{netflow,holdings}, tgm/holders
NANSEN_API_KEY=
NANSEN_BASE_URL=https://api.nansen.ai/api/v1

# ------------ Defaults ------------
# base | ethereum | bsc | polygon | arbitrum | optimism | solana | avalanche
DEFAULT_CHAIN=base

# ------------ Optional ------------
# Used for the BTC 7d market context line in the bot summary
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# Optional: handle for the deployed Telegram bot (used on the landing page)
NEXT_PUBLIC_BOT_HANDLE=@hodlsmith_bot
